{
  "version": 2,
  "name": "who-dat",
  "builds": [
    {
      "src": "cmd/vercel/single/index.go",
      "use": "@vercel/go"
    },
    {
      "src": "cmd/vercel/multi/index.go",
      "use": "@vercel/go"
    },
    {
      "src": "cmd/vercel/health/index.go",
      "use": "@vercel/go"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/ping",
      "dest": "/cmd/vercel/health/index.go"
    },
    {
      "src": "/multi(.*)",
      "dest": "/cmd/vercel/multi/index.go"
    },
    {
      "src": "/(.*)",
      "dest": "/cmd/vercel/single/index.go"
    }
  ],
  "headers": [
    {
      "source": "/((?!ping|multi).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/multi(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=1800, stale-while-revalidate=3600"
        }
      ]
    }
  ],
  "env": {
    "GO111MODULE": "on"
  }
}
